rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Check roles based on Firebase Auth email address
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@harinos.local';
    }
    
    function isManager() {
      return request.auth != null && request.auth.token.email == 'manager@harinos.local';
    }
    
    function isStaff() {
      return request.auth != null && request.auth.token.email == 'staff@harinos.local';
    }
    
    function isAdminOrManager() {
      return isAdmin() || isManager();
    }
    
    function isStaffUser() {
      return isAdmin() || isManager() || isStaff();
    }

    // Orders Rules: Customers need public read/write access (unauthenticated)
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Customers Rules: Customers need public read/write access (unauthenticated)
    match /customers/{customerId} {
      allow read, write: if true;
    }

    match /customerProfiles/{customerId} {
      allow read, write: if true;
    }

    // Verification Requests Rules
    match /customerVerificationRequests/{requestId} {
      allow read, write: if true;
    }

    // Wallets Rules
    match /wallets/{walletId} {
      allow read, write: if true;
    }

    // Wallet Transactions Rules
    match /wallet_transactions/{transactionId} {
      allow read, write: if true;
    }

    match /walletTransactions/{transactionId} {
      allow read, write: if true;
    }

    // Menu Items Rules: Public read, Admin/Manager write or bootstrapping
    match /menu_items/{itemId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdminOrManager() || !exists(/databases/$(database)/documents/admins/Admin_Harinos);
    }

    // Outlets Rules: Public read, Admin/Manager write or bootstrapping
    match /outlets/{outletId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdminOrManager() || !exists(/databases/$(database)/documents/admins/Admin_Harinos);
    }

    // Offers Rules: Public read, Admin/Manager write or bootstrapping
    match /offers/{offerId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdminOrManager() || !exists(/databases/$(database)/documents/admins/Admin_Harinos);
    }

    // Role-specific Collections Rules: Public read for login check, write restricted except bootstrapping
    match /admins/{username} {
      allow read: if true;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/admins/Admin_Harinos);
      allow delete: if false;
    }

    match /managers/{username} {
      allow read: if true;
      allow write: if isAdminOrManager() || !exists(/databases/$(database)/documents/admins/Admin_Harinos);
      allow delete: if isAdmin();
    }

    match /staff/{username} {
      allow read: if true;
      allow write: if isStaffUser() || !exists(/databases/$(database)/documents/admins/Admin_Harinos);
      allow delete: if isAdminOrManager();
    }

    // Application Settings Rules: Public read, Admin/Manager write or bootstrapping
    match /settings/{settingsId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdminOrManager() || !exists(/databases/$(database)/documents/admins/Admin_Harinos);
    }

    match /storeConfiguration/{configId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdminOrManager() || !exists(/databases/$(database)/documents/admins/Admin_Harinos);
    }

    // Notifications Rules: Public read/write
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // User Sessions Rules: Public read/write
    match /userSessions/{username} {
      allow read, write: if true;
    }

    // Security & Audit Logs Rules
    match /security_logs/{logId} {
      allow read: if isAdmin();
      allow write: if true;
      allow delete: if false;
    }

    // Usage Rules
    match /firestore_usage/{usageId} {
      allow read: if isAdminOrManager();
      allow write, delete: if false;
    }

    match /notification_stats/{statsId} {
      allow read: if isAdminOrManager();
      allow write, delete: if false;
    }

    // Devices & Token Rules
    match /notification_tokens/{tokenId} {
      allow read, write: if true;
    }
    
    // Referrals Rules
    match /referrals/{referralId} {
      allow read, write: if true;
    }

    // Customer History
    match /customerHistory/{customerId} {
      allow read, write: if true;
    }

    // Order History
    match /orderHistory/{orderId} {
      allow read, write: if true;
    }
    
    // Business Data
    match /businessData/{dataId} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }

    // Legacy Customers Rules
    match /legacyCustomers/{customerId} {
      allow read, write: if true;
    }

    // Blocked Customers Rules
    match /blocked_customers/{phone} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Yearly Summaries Rules
    match /yearlySummaries/{summaryId} {
      allow read, write: if isAdminOrManager();
    }

    // Customer Verification Rules
    match /customerVerification/{customerId} {
      allow read, write: if true;
    }

    // Analytics Rules
    match /analytics/{analyticsId} {
      allow read, write: if true;
    }
  }
}
