rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Check roles based on Firebase Auth email address
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@harinos.local';
    }
    
    function isManager() {
      return request.auth != null && request.auth.token.email == 'manager@harinos.local';
    }
    
    function isStaff() {
      return request.auth != null && request.auth.token.email == 'staff@harinos.local';
    }
    
    function isAdminOrManager() {
      return isAdmin() || isManager();
    }
    
    function isStaffUser() {
      return isAdmin() || isManager() || isStaff();
    }

    // Orders Rules
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (isStaffUser() || request.auth.token.email == 'customer_' + resource.data.customerPhone + '@harinos.local');
      allow delete: if isAdminOrManager();
    }

    // Customers Rules
    match /customers/{customerId} {
      allow read, write: if request.auth != null && (isAdminOrManager() || request.auth.token.email == 'customer_' + customerId + '@harinos.local');
      allow delete: if isAdminOrManager();
    }

    match /customerProfiles/{customerId} {
      allow read, write: if request.auth != null && (isAdminOrManager() || request.auth.token.email == 'customer_' + customerId + '@harinos.local');
      allow delete: if isAdminOrManager();
    }

    // Verification Requests Rules
    match /customerVerificationRequests/{requestId} {
      allow read, write: if request.auth != null && (isAdminOrManager() || request.auth.token.email == 'customer_' + requestId + '@harinos.local');
      allow delete: if isAdminOrManager();
    }

    // Wallets Rules
    match /wallets/{walletId} {
      allow read: if request.auth != null && (isAdminOrManager() || request.auth.token.email == 'customer_' + walletId + '@harinos.local');
      allow write: if isAdminOrManager();
      allow delete: if isAdminOrManager();
    }

    // Wallet Transactions Rules
    match /wallet_transactions/{transactionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdminOrManager();
    }

    match /walletTransactions/{transactionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdminOrManager();
    }

    // Menu Items Rules
    match /menu_items/{itemId} {
      allow read: if true;
      allow write, delete: if isAdminOrManager();
    }

    // Outlets Rules
    match /outlets/{outletId} {
      allow read: if true;
      allow write, delete: if isAdminOrManager();
    }

    // Offers Rules
    match /offers/{offerId} {
      allow read: if true;
      allow write, delete: if isAdminOrManager();
    }

    // Role-specific Collections Rules
    match /admins/{username} {
      allow read, write: if isAdmin();
      allow delete: if false;
    }

    match /managers/{username} {
      allow read, write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /staff/{username} {
      allow read, write: if isAdminOrManager();
      allow delete: if isAdminOrManager();
    }

    // Application Settings Rules
    match /settings/{settingsId} {
      allow read: if true;
      allow write, delete: if isAdminOrManager();
    }

    // Security & Audit Logs Rules
    match /security_logs/{logId} {
      allow read: if isAdmin();
      allow write: if request.auth != null;
      allow delete: if false;
    }

    // Usage Rules
    match /firestore_usage/{usageId} {
      allow read: if isAdminOrManager();
      allow write, delete: if false;
    }

    match /notification_stats/{statsId} {
      allow read: if isAdminOrManager();
      allow write, delete: if false;
    }

    // Devices & Token Rules
    match /notification_tokens/{tokenId} {
      allow read: if isAdminOrManager();
      allow write, delete: if true;
    }
  }
}
