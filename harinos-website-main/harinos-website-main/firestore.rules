rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Orders Collection Rules: Block all direct client SDK reads/writes
    match /orders/{orderId} {
      allow read, write, delete: if false;
    }

    // Customers Collection Rules: Block all direct client SDK reads/writes
    match /customers/{customerId} {
      allow read, write, delete: if false;
    }

    // Wallet Transactions Rules: Block all direct client SDK reads/writes
    match /wallet_transactions/{transactionId} {
      allow read, write, delete: if false;
    }

    // Menu Items Rules: Read-only for public, writes must go through API (blocked on client SDK)
    match /menu_items/{itemId} {
      allow read: if true;
      allow write, delete: if false;
    }

    // Outlets Rules: Read-only for public, writes must go through API (blocked on client SDK)
    match /outlets/{outletId} {
      allow read: if true;
      allow write, delete: if false;
    }

    // Offers Rules: Read-only for public, writes must go through API (blocked on client SDK)
    match /offers/{offerId} {
      allow read: if true;
      allow write, delete: if false;
    }

    // Users Rules: Block all direct client SDK reads/writes
    match /users/{username} {
      allow read, write, delete: if false;
    }

    // Notification Tokens Rules: Block all direct client SDK reads/writes
    match /notification_tokens/{tokenId} {
      allow read, write, delete: if false;
    }

    // Notification Log Rules: Block all direct client SDK reads/writes
    match /notification_log/{logId} {
      allow read, write, delete: if false;
    }

    // Security Logs Rules: Block all direct client SDK reads/writes
    match /security_logs/{logId} {
      allow read, write, delete: if false;
    }
  }
}
