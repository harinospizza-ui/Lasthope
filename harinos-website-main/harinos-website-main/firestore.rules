rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user has a specific role claim in their auth token
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    // Orders Collection Rules
    match /orders/{orderId} {
      // Allow read if the caller is the owning customer (matching phone or email) or an authenticated staff/manager/admin
      allow read: if (isAuthenticated() && (
        request.auth.token.phone == resource.data.customerPhone ||
        request.auth.token.email == resource.data.customerEmail ||
        request.auth.token.role in ['admin', 'manager', 'staff']
      )) || (!isAuthenticated() && false); // Force all writes/reads to be authenticated or done via secure serverless API
      
      // Allow creation for matching customer or authenticated staff/manager/admin
      allow create, update: if (isAuthenticated() && (
        request.auth.token.phone == request.resource.data.customerPhone ||
        request.auth.token.role in ['admin', 'manager']
      )) || (!isAuthenticated() && false); // Secure serverless API bypasses this rule
      
      // Delete is strictly blocked for client SDK. Admin/Manager must use serverless API (Admin SDK)
      allow delete: if false;
    }

    // Customers Collection Rules
    match /customers/{customerId} {
      // Customers can read/write their own profile only
      allow read, write: if isAuthenticated() && (
        request.auth.uid == customerId ||
        request.auth.token.role in ['admin', 'manager']
      );
      allow delete: if false;
    }

    // Wallet Transactions Rules
    match /wallet_transactions/{transactionId} {
      // Only the owning customer or managers/admins can read transactions. No client writes allowed.
      allow read: if isAuthenticated() && (
        request.auth.token.phone == resource.data.customerPhone ||
        request.auth.token.role in ['admin', 'manager']
      );
      allow write, delete: if false; // All modifications must go through secure serverless API
    }

    // Menu Items Rules
    match /menu_items/{itemId} {
      allow read: if true; // Public read-only
      allow write: if isAuthenticated() && request.auth.token.role in ['admin', 'manager'];
      allow delete: if isAuthenticated() && request.auth.token.role == 'admin';
    }

    // Outlets Rules
    match /outlets/{outletId} {
      allow read: if true; // Public read-only
      allow write: if isAuthenticated() && request.auth.token.role in ['admin', 'manager'];
      allow delete: if isAuthenticated() && request.auth.token.role == 'admin';
    }

    // Offers Rules
    match /offers/{offerId} {
      allow read: if true; // Public read-only
      allow write: if isAuthenticated() && request.auth.token.role in ['admin', 'manager'];
      allow delete: if isAuthenticated() && request.auth.token.role == 'admin';
    }

    // Staff Users Rules
    match /staff_users/{username} {
      // Completely block all client SDK operations. Must go through the secure Vercel API only.
      allow read, write, delete: if false;
    }

    // Security Logs Rules
    match /security_logs/{logId} {
      allow read, write, delete: if false; // Only accessible via serverless backend
    }
  }
}
